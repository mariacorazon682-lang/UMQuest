<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".teacherlogin">

        <ImageView
            android:id="@+id/backgroundGif4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            tools:src="@drawable/bubbles"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@android:color/transparent"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0">


            <androidx.cardview.widget.CardView
                android:layout_width="270dp"
                android:layout_height="270dp"
                android:layout_marginTop="130dp"
                app:cardElevation="0dp"
                android:backgroundTint="@android:color/transparent">

                <ImageButton
                    android:id="@+id/imagelogo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="fitCenter"
                    android:transitionName="logo_shared_element"
                    app:srcCompat="@drawable/umquestlogo" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/whiteboard_layout"
                android:layout_marginTop="35dp"
                android:layout_width="match_parent"
                android:layout_height="500dp"
                android:background="@drawable/whiteboard"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="210dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="10dp"
                    android:background="@android:color/transparent"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:layout_width="70dp"
                        app:cardElevation="0dp"
                        android:layout_gravity="center"
                        android:backgroundTint="@android:color/transparent"
                        android:layout_height="match_parent">
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/imageView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:srcCompat="@drawable/blueteacher" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/textView20"
                        android:layout_width="10dp"
                        android:layout_height="70dp"
                        android:layout_weight="3"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:text="Welcome"
                        android:textColor="@color/blue"
                        android:textSize="33dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:textAlignment="center">

                    <TextView
                        android:id="@+id/textView30"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:text="Sign in to continue!"
                        android:textAlignment="center"
                        android:textColor="@color/ice"
                        android:textSize="25dp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/textUsernameTch"
                        android:layout_width="300dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/button_outline2"
                        android:padding="5dp"
                        android:hint="  Username"
                        android:textColorHint="@color/pale_blue"
                        android:textSize="20dp" />

                    <EditText
                        android:id="@+id/textPasswordTch"
                        android:layout_width="300dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/button_outline2"
                        android:padding="5dp"
                        android:hint="  Password"
                        android:inputType="textPassword"
                        android:textColorHint="@color/pale_blue"
                        android:textSize="20dp" />

                    <TextView
                        android:id="@+id/forgotpass2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Forgot Password?"
                        android:textAlignment="center"
                        android:textColor="@color/blue"
                        android:textSize="23dp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btn_logintch"
                        android:layout_width="300dp"
                        android:layout_height="45dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/button_blue"
                        android:text="Login"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="20dp"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:textSize="18dp"
                            android:layout_height="wrap_content"
                            android:text="I am a new user "
                            android:textColor="@color/ocean_blue" />

                        <TextView
                            android:id="@+id/textlogintch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:textSize="18dp"
                            android:textColor="@color/blue"
                            android:text="Sign up" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>