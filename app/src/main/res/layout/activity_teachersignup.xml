<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".teachersignup">

    <ImageView
        android:id="@+id/backgroundGifSignup2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        tools:src="@drawable/bubbles"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <androidx.cardview.widget.CardView
            android:layout_width="230dp"
            android:layout_height="230dp"
            app:cardElevation="0dp"
            android:backgroundTint="@android:color/transparent">

            <ImageButton
                android:id="@+id/logo_signup_tch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:transitionName="logo_shared_element"
                app:srcCompat="@drawable/umquestlogo" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/whiteboard_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="20dp"
            android:background="@drawable/whiteboard"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="70dp"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:background="@android:color/transparent"
                android:orientation="horizontal">

                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    app:srcCompat="@drawable/blueteacher" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="5dp"
                    android:textStyle="bold"
                    android:text="Create"
                    android:textColor="@color/blue"
                    android:textSize="40dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign up to get started!"
                android:textAlignment="center"
                android:textColor="@color/ice"
                android:textSize="27dp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:gravity="center">

                <EditText
                    android:id="@+id/usertchsgn"
                    android:layout_width="300dp"
                    android:layout_height="40dp"
                    android:background="@drawable/button_outline2"
                    android:padding="5dp"
                    android:hint="  Username"
                    android:textColorHint="@color/pale_blue"
                    android:textSize="20dp" />

                <EditText
                    android:id="@+id/emailtchsgn"
                    android:layout_width="300dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/button_outline2"
                    android:padding="5dp"
                    android:hint="  Email"
                    android:inputType="textEmailAddress"
                    android:textColorHint="@color/pale_blue"
                    android:textSize="20dp" />

                <EditText
                    android:id="@+id/teacherId"
                    android:layout_width="300dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/button_outline2"
                    android:padding="5dp"
                    android:hint="  Teacher ID"
                    android:textColorHint="@color/pale_blue"
                    android:textSize="20dp" />

                <EditText
                    android:id="@+id/passwordtchsgn"
                    android:layout_width="300dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/button_outline2"
                    android:padding="5dp"
                    android:hint="  Password"
                    android:inputType="textPassword"
                    android:textColorHint="@color/pale_blue"
                    android:textSize="20dp" />

                <EditText
                    android:id="@+id/confirmpasswordtchsgn"
                    android:layout_width="300dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/button_outline2"
                    android:padding="5dp"
                    android:hint="  Confirm Password"
                    android:inputType="textPassword"
                    android:textColorHint="@color/pale_blue"
                    android:textSize="20dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18dp"
                        android:text="I agree to the "
                        android:textColor="@color/ocean_blue" />

                    <TextView
                        android:id="@+id/terms2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="18dp"
                        android:textColor="@color/blue"
                        android:text="Terms and Condition" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_createtch"
                    android:layout_width="300dp"
                    android:layout_height="55dp"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/button_blue"
                    android:text="Create"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="28dp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:textSize="18dp"
                        android:layout_height="wrap_content"
                        android:text="I already have an account "
                        android:textColor="@color/ocean_blue" />

                    <TextView
                        android:id="@+id/textSignInTch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="18dp"
                        android:textColor="@color/blue"
                        android:text="Sign in" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>